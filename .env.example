# Environment Variables for the local parity stack.
# Copy this file to .env and adjust values if you want to override defaults.

# Image selection
BACKEND_IMAGE=ghcr.io/aldervon-systems/vendingbackpack/backend:latest
FRONTEND_IMAGE=ghcr.io/aldervon-systems/vendingbackpack/frontend-next:latest

# Local Rails secret for the image-based stack.
# Replace this for anything beyond local development.
SECRET_KEY_BASE=change-me-for-local-dev

# Notes:
# - Local parity mode expects access to GHCR images.
# - Run `docker login ghcr.io` if image pulls are denied.
# - The base stack now targets the Next frontend by default.
