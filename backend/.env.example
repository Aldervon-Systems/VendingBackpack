# Environment Variables for Backend
# Copy this file to .env and fill in your values

# Database Configuration
# For SQLite (local development):
DATABASE_URL=sqlite:///./vending_backpack.db

# For PostgreSQL (production):
# DATABASE_URL=postgresql://vending_user:your_password@postgres:5432/vending_backpack
# OR use DB_URI format:
# DB_URI=postgresql://vending_user:your_password@postgres:5432/vending_backpack

# Application Settings
ENVIRONMENT=development
DEBUG=True

# API Settings
API_HOST=0.0.0.0
API_PORT=8080
